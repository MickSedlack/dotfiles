#
# hotkey for media and runners
# 'wm agnostic' pff plain media keys and control programs

alt + space
    ~/.config/drun/customrun.sh 1 &

alt + p
    ~/.config/drun/poweroptions.sh

alt + k
    ~/.config/drun/dmenu-bluetooth 'B' -fn 'Inconsolata Nerd Font Mono-16' &

alt + l
    i3lock -e -c 000000

Print
    ~/.config/drun/dmenushot.sh

XF86AudioLowerVolume
    ~/.config/drun/volumeControl.sh down &

XF86AudioRaiseVolume
   ~/.config/drun/volumeControl.sh up &

XF86AudioMute
    ~/.config/drun/volumeControl.sh mute &

Pause
    playerctl play-pause

shift + Prior
    playerctl next

shift + Next
    playerctl previous

